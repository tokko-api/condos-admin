# ===========================================
# condos-admin - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!
# ===========================================

# ===========================================
# Traefik (API Gateway)
# ===========================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8089

# Email para Let's Encrypt (emision de certificados SSL). OBLIGATORIO en prod.
ACME_EMAIL=tu-email@tu-dominio.com

# ===========================================
# Project Configuration
# ===========================================
PROJECT_NAME=condos
NETWORK_NAME=condos-admin-net

# ===========================================
# MongoDB Configuration
# ===========================================
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=<your-mongodb-username>
MONGO_INITDB_ROOT_PASSWORD=<your-mongodb-password>
MONGO_INITDB_DATABASE=condos

# MongoDB Connection URI (for Spring Boot services)
# IMPORTANTE: usa el APP_MONGO_USER/APP_MONGO_PASSWORD de abajo (no el root),
# y authSource=condos porque mongo_init/init.js crea ese usuario en la DB "condos".
SPRING_DATA_MONGODB_URI=mongodb://<app-username>:<app-password>@mongo:27017/condos?authSource=condos

# App user created by mongo_init/init.js on first boot (used by SPRING_DATA_MONGODB_URI above).
# Must match the username/password you put in SPRING_DATA_MONGODB_URI.
APP_MONGO_USER=<your-app-mongo-username>
APP_MONGO_PASSWORD=<your-app-mongo-password>

# ===========================================
# JWT Security
# ===========================================
# IMPORTANT: Use a strong secret of at least 64 characters in production
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=<your-jwt-secret-min-64-characters>

# JWT token expiration in minutes (default: 240 = 4 hours)
JWT_EXPIRES_MINUTES=240

# ===========================================
# MinIO (Object Storage)
# ===========================================
MINIO_ROOT_USER=ASDFJLAFGJDAFg34578
MINIO_ROOT_PASSWORD=SDFGMKL345dgfsgfsdf
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===========================================
# Spring Profiles
# ===========================================
# Use 'dev' for local development, 'prod' for production
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Internal API Communication
# ===========================================
# Secret for internal API-to-API authentication
INTERNAL_API_SECRET=<your-internal-api-secret>

# ===========================================
# Frontend Configuration (if applicable)
# ===========================================
# FRONTEND_URL=http://localhost:3000
# API_BASE_URL=http://localhost:8080